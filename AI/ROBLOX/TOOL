local function setSliderFromTransparency()
	local t = clamp(Settings.Transparency, 0, 0.45)
	local pct = t / 0.45
	local w = Slider.AbsoluteSize.X
	local x = pct * w
	Fill.Size = UDim2.new(0, x, 1, 0)
	Knob.Position = UDim2.new(0, x, 0.5, 0)
	TransLbl.Text = ("Main transparency: %.2f (0.00 - 0.45)"):format(t)
end

local function setTransparencyFromMouse(xPos)
	local absX = Slider.AbsolutePosition.X
	local w = Slider.AbsoluteSize.X
	local pct = clamp((xPos - absX) / w, 0, 1)
	Settings.Transparency = pct * 0.45
	applySettings()
	setSliderFromTransparency()
end

Slider.InputBegan:Connect(function(inp)
	if inp.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = true
		setTransparencyFromMouse(inp.Position.X)
	end
end)

UIS.InputChanged:Connect(function(inp)
	if dragging and inp.UserInputType == Enum.UserInputType.MouseMovement then
		setTransparencyFromMouse(inp.Position.X)
	end
end)

UIS.InputEnded:Connect(function(inp)
	if inp.UserInputType == Enum.UserInputType.MouseButton1 then
