	if inp.UserInputType == Enum.UserInputType.MouseButton1 then
		local mpos = inp.Position
		local absPos, absSize = Modal.AbsolutePosition, Modal.AbsoluteSize
		local inside =
			mpos.X >= absPos.X and mpos.X <= absPos.X + absSize.X and
			mpos.Y >= absPos.Y and mpos.Y <= absPos.Y + absSize.Y
		if not inside then
			closeModal()
		end
	end
end)

