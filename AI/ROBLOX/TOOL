local function splitArgs(s)
	local t = {}
	for w in tostring(s):gmatch("%S+") do
		table.insert(t, w)
	end
	return t
end

local function setPendingScript(note, code)
	Exec.PendingNote = tostring(note or "")
	Exec.PendingCode = tostring(code or "")

	CMD:Success("Script proposed (NOT run). Type: /approve  |  /reject")
	if Exec.PendingNote ~= "" then
		CMD:Print("Note: " .. Exec.PendingNote)
	end

	CMD:Print("Preview:")
	for line in Exec.PendingCode:gmatch("[^\n]+") do
		CMD:Print(line)
	end
end

local function approveAndRun()
	if not Exec.PendingCode or Exec.PendingCode == "" then
		CMD:Error("No pending script to run.")
		return
	end

	if #Exec.PendingCode > 2000 then
		CMD:Error("Pending script too large.")
		return
	end

	CMD:Success("Running approved script...")

	local fn, err = loadstring(Exec.PendingCode)
	if not fn then
		CMD:Error("Compile error: " .. tostring(err))
		return
	end

	local ok, runtimeErr = pcall(fn)
	if not ok then
		CMD:Error("Runtime error: " .. tostring(runtimeErr))
	else
		CMD:Success("Done.")
	end

	Exec.PendingCode, Exec.PendingNote = nil, nil
end

