local function copyToClipboard(txt)
	txt = tostring(txt or "")

	local candidates = {
		-- most common
		setclipboard,
		toclipboard,
		set_clipboard,

		-- Synapse-style variants
		(syn and syn.setclipboard) or nil,
		(syn and syn.set_clipboard) or nil,

		-- KRNL / others sometimes expose this
		(setClipboard) or nil,
		(toClipboard) or nil,

		-- Fluxus-style (some envs)
		(getgenv and getgenv().setclipboard) or nil,
		(getgenv and getgenv().set_clipboard) or nil,
	}

	for _, fn in ipairs(candidates) do
		if typeof(fn) == "function" then
			local ok = pcall(fn, txt)
			if ok then return true end
		end
	end

	return false
end

