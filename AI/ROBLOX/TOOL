local function httpPostJson(url, bodyTable, headers)
	local req =
		(syn and syn.request)
		or request
		or http_request
		or (http and http.request)

	if not req then
		return nil, "No request function found (syn.request/request/http_request)."
	end

	local res = req({
		Url = url,
		Method = "POST",
		Headers = headers,
		Body = HttpService:JSONEncode(bodyTable),
	})

	if not res then return nil, "No response" end
	local code = tonumber(res.StatusCode) or 0
	if code < 200 or code >= 300 then
		return nil, ("HTTP %s: %s"):format(tostring(code), tostring(res.Body))
	end
	return res.Body
end

local thinkingThread = nil
local function setAiThinking(on)
	if on then
		local alive = true
		if thinkingThread then
			thinkingThread.alive = false
		end
		thinkingThread = { alive = true }
		local token = thinkingThread

		task.spawn(function()
			local dots = 0
			while token.alive and ui.Parent do
				dots = (dots + 1) % 4
				AiStatus.Text = "AI: thinking" .. string.rep(".", dots)
				task.wait(0.25)
			end
		end)
	else
		if thinkingThread then
			thinkingThread.alive = false
			thinkingThread = nil
		end
		if ui.Parent then
			AiStatus.Text = minimized and "AI: idle (minimized)" or "AI: idle"
		end
	end
end

local function openrouterGetAction(userText)
	if not AI.OPENROUTER_KEY or AI.OPENROUTER_KEY == "" or AI.OPENROUTER_KEY:find("PASTE_", 1, true) then
		return nil, "No OpenRouter key set. Put it into AI.OPENROUTER_KEY."
	end
	if not AI.MODEL or AI.MODEL == "" then
		return nil, "No model set. Put it into AI.MODEL."
	end

	local system = [[
You are the brain for a Roblox command prompt UI.
Return exactly ONE JSON object only (no markdown).

Allowed actions:
- say: {"action":"say","text":"..."}
- cmd: {"action":"cmd","name":"<local_command>","args":["..."]}
- propose_script: {"action":"propose_script","note":"what it does","code":"lua..."}
- run_approved: {"action":"run_approved"}

Rules:
- IMPORTANT: Local (non-AI) commands only exist when the user types them with a leading slash, e.g. "/tp 0 10 0" or "/whoami".
- If the user types WITHOUT "/", treat it as normal chat/AI request.
- Prefer cmd when user clearly asked for a slash-command.
- If code is needed, use propose_script.
- NEVER claim you executed code unless the user explicitly approved it.
- Keep code under 2000 characters.
- If the user asks to run it now, return run_approved.
- Otherwise use say.

Return ONLY JSON.
]]

	local bodyTable = {
		model = AI.MODEL,
		temperature = 0.2,
		max_tokens = 200,
		messages = {
			{ role = "system", content = system },
			{ role = "user", content = tostring(userText) },
		},
		response_format = { type = "json_object" },
	}

	local headers = {
		["Content-Type"] = "application/json",
		["Authorization"] = "Bearer " .. AI.OPENROUTER_KEY,
		["X-Title"] = AI.APP_NAME or "Roblox CMD UI",
	}

	setAiThinking(true)
	local raw, err = httpPostJson(AI.ENDPOINT, bodyTable, headers)
	setAiThinking(false)

	if not raw then return nil, err end

	local decoded = HttpService:JSONDecode(raw)
	local content = ""
	pcall(function()
		content = decoded.choices[1].message.content or ""
	end)

	content = tostring(content):gsub("^%s+", ""):gsub("%s+$", "")
	if content == "" then
		return nil, "AI returned empty content."
	end

	local actionObj
	local ok = pcall(function()
		actionObj = HttpService:JSONDecode(content)
	end)

	if not ok or type(actionObj) ~= "table" then
		return { action = "say", text = "I couldn't parse that. Try /help." }
	end

	return actionObj
end

local function handleCommand(raw)
	local cmd = tostring(raw or ""):gsub("^%s+", ""):gsub("%s+$", "")
	if cmd == "" then
		CMD:Print(">")
		return
	end

	CMD:Print("> " .. cmd)

	if cmd:sub(1, 1) == "/" then
		local withoutSlash = cmd:sub(2)
		local parts = splitArgs(withoutSlash)
		local name = (parts[1] or ""):lower()
		table.remove(parts, 1)

		local fn = LocalCommands[name]
		if fn then
			fn(parts)
		else
			CMD:Error("Unknown local command: /" .. tostring(name))
			CMD:Print("Type /help for local commands.")
		end
		return
	end

	local actionObj, err = openrouterGetAction(cmd)
	if not actionObj then
		CMD:Error(tostring(err))
		return
	end

	local action = tostring(actionObj.action or ""):lower()

	if action == "say" then
		CMD:Print(tostring(actionObj.text or "ok"))

	elseif action == "cmd" then
		local name = tostring(actionObj.name or ""):lower()
		CMD:Print("AI suggests local command: /" .. name .. " (run it with '/').")

	elseif action == "propose_script" then
		setPendingScript(actionObj.note, actionObj.code)

	elseif action == "run_approved" then
		CMD:Print("Type '/approve' to run the last proposed script.")

	else
		CMD:Error("Unknown AI action: " .. tostring(action))
	end
end

