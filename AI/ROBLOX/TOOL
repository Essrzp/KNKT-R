local expr = "0"

local function setExpr(s)
	expr = tostring(s or "0")
	if expr == "" then expr = "0" end
	Display.Text = expr
end

local function appendDigit(d)
	if expr == "0" then
		setExpr(d)
	else
		setExpr(expr .. d)
	end
end

local function clearExpr()
	setExpr("0")
end

local function tryAddOperator(op)
	if Perk == "Free" then
		showOperatorUpsell(op)
		return
	end
	setExpr(expr .. " " .. op .. " ")
end

local function tryEquals()
	if Perk ~= "Premium" then
		showEqualsUpsell()
		return
	end

	local safe = expr:gsub("x", "*")
	if safe:find("[^%d%s%+%-%*/%.%*]") then
		setExpr("ERR")
		return
	end

	local ok, result = pcall(function()
		local f = loadstring("return " .. safe)
		return f and f() or nil
	end)

	if ok and result ~= nil and tostring(result) ~= "nan" then
		setExpr(tostring(result))
	else
		setExpr("ERR")
	end
end

