local function handleCommand(raw)
	local cmd = tostring(raw or ""):gsub("^%s+", ""):gsub("%s+$", "")
	if cmd == "" then
		CMD:Print(">")
		return
	end

	CMD:Print("> " .. cmd)

	-- FIX: use todayDate() + ensure LastUnlockDate exists
	if not GATE.LOCKED and (not GATE.LastUnlockDate or GATE.LastUnlockDate ~= todayDate()) then
		GATE.LOCKED = true
		CMD:Error("Daily key expired. Please /key <today's code> again.")
		return
	end

	if GATE.LOCKED and cmd:sub(1, 1) ~= "/" then
		CMD:Error("Gate locked, Open (Top-left) >Get Key")
		return
	end

	if cmd:sub(1, 1) == "/" then
		local withoutSlash = cmd:sub(2)
		local parts = splitArgs(withoutSlash)
		local name = (parts[1] or ""):lower()
		table.remove(parts, 1)

		local fn = LocalCommands[name]
		if fn then
			fn(parts)
		else
			CMD:Error("Unknown local command: /" .. tostring(name))
			CMD:Print("Type /help for local commands.")
		end
		return
	end

	local actionObj, err = geminiGetAction(cmd)
	if not actionObj then
		CMD:Error(tostring(err))
		return
	end

	local action = tostring(actionObj.action or ""):lower()

	if action == "say" then
		CMD:Print(tostring(actionObj.text or "ok"))

	elseif action == "cmd" then
		local name = tostring(actionObj.name or ""):lower()
		CMD:Print("AI suggests local command: /" .. name .. " (run it with '/').")

	elseif action == "propose_script" then
		setPendingScript(actionObj.note, actionObj.code)

	elseif action == "run_approved" then
		CMD:Print("Type '/approve' to run the last proposed script.")

	else
		CMD:Error("Unknown AI action: " .. tostring(action))
	end
end

