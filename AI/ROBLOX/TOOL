local function httpPostJson(url, bodyTable, headers)
	local req =
		(syn and syn.request)
		or request
		or http_request
		or (http and http.request)

	if not req then
		return nil, "No request function found (syn.request/request/http_request)."
	end

	local res = req({
		Url = url,
		Method = "POST",
		Headers = headers,
		Body = HttpService:JSONEncode(bodyTable),
	})

	if not res then return nil, "No response" end
	local code = tonumber(res.StatusCode) or 0
	if code < 200 or code >= 300 then
		return nil, ("HTTP %s: %s"):format(tostring(code), tostring(res.Body))
	end
	return res.Body
end

-- FIX: now assigned to the forward-declared variable
verifyDailyCode = function(code)
	code = tostring(code or ""):gsub("%s+", "")

	-- must be exactly 7 digits
	if not code:match("^%d%d%d%d%d%d%d$") then
		return false, "Code must be 7 digits."
	end

	local req =
		(syn and syn.request)
		or request
		or http_request
		or (http and http.request)

	if not req then
		return false, "No request function found (syn.request/request/http_request)."
	end

	local res = req({
		Url = GATE.VERIFY_URL,
		Method = "POST",
		Headers = { ["Content-Type"] = "application/json" },
		Body = HttpService:JSONEncode({ code = code }),
	})

	if not res then
		return false, "No response from verify server."
	end

	local status = tonumber(res.StatusCode) or 0
	if status < 200 or status >= 300 then
		return false, ("Verify failed HTTP %s"):format(status)
	end

	local data
	local ok = pcall(function()
		data = HttpService:JSONDecode(res.Body)
	end)
	if not ok or type(data) ~= "table" then
		return false, "Bad verify response."
	end

	if data.ok == true then
		return true, "OK"
	end

	return false, tostring(data.reason or "wrong_code")
end

