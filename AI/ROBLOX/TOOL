local function getRegionalPrices()
	local loc = tostring(LocalizationService.RobloxLocaleId or "en-us"):lower()
	local currency = "$"
	if loc:find("nl") or loc:find("de") or loc:find("fr") or loc:find("es") or loc:find("it") or loc:find("pt") then
