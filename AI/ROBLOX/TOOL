local function typeLine(text, color, cps)
	cps = cps or Settings.TypeSpeed

	if not Settings.Animations then
		addLine(tostring(text or ""), color or Color3.fromRGB(255,255,255))
		return
	end

	local L = Instance.new("TextLabel")
	L.Parent = Output
	L.BackgroundTransparency = 1
	L.BorderSizePixel = 0
	L.Size = UDim2.new(1, -6, 0, 18)
	L.Font = Enum.Font.Code
	L.TextSize = 14
	L.TextXAlignment = Enum.TextXAlignment.Left
	L.TextYAlignment = Enum.TextYAlignment.Center
	L.TextColor3 = color or Color3.fromRGB(255,255,255)
	L.Text = ""

	task.wait()
	Output.CanvasSize = UDim2.new(0, 0, 0, Layout.AbsoluteContentSize.Y + 2)
	Output.CanvasPosition = Vector2.new(0, math.max(0, Layout.AbsoluteContentSize.Y))

	local s = tostring(text or "")
	for i = 1, #s do
		L.Text = s:sub(1, i)
		task.wait(1 / cps)
	end

	task.wait()
	Output.CanvasSize = UDim2.new(0, 0, 0, Layout.AbsoluteContentSize.Y + 2)
	Output.CanvasPosition = Vector2.new(0, math.max(0, Layout.AbsoluteContentSize.Y))
end

local function bootSequence()
	if not Settings.Animations then
	Output.Visible = true
	InputHolder.Visible = true
	CMD:Success("AI CMD ready. Type /help (local).")
	return
end
	-- save your normal size/pos
	local fullSize = Main.Size
	local fullPos = Main.Position
	local fullAnchor = Main.AnchorPoint

	-- start as bar only (same place)
	Output.Visible = false
	InputHolder.Visible = false
	Main.Active = false
	Main.Draggable = false

	Main.AnchorPoint = Vector2.new(0, 0)
	Main.Position = fullPos
	Main.Size = UDim2.new(0, fullSize.X.Offset, 0, 30)

	-- wait with bar
	task.wait(0.5)

	-- expand animation
	local tw = TweenService:Create(
		Main,
		TweenInfo.new(0.28, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
		{ Size = fullSize }
	)
	tw:Play()
	tw.Completed:Wait()

	-- restore drag + reveal
	Main.AnchorPoint = fullAnchor
	Main.Position = fullPos
	Main.Active = true
	Main.Draggable = true

	Output.Visible = true
	InputHolder.Visible = true

	-- optional: clear anything that got printed before boot
	for _, v in ipairs(Output:GetChildren()) do
		if v:IsA("TextLabel") then v:Destroy() end
	end
	task.wait()
	Output.CanvasSize = UDim2.new(0, 0, 0, 0)
	Output.CanvasPosition = Vector2.new(0, 0)

	-- type-print startup lines
	typeLine("AI CMD ready.", Color3.fromRGB(170, 120, 255), 70)
	typeLine("Type /help (local).", Color3.fromRGB(170, 120, 255), 70)
end
